# Email configuration (required for discount emails & lockout notifications)
# For Gmail: use an App Password — https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin credentials (used for login; stored in Supabase when configured)
ADMIN_USER=AlgoCoffee
ADMIN_PASS=Algo123

# Admin notification recipient (lockout alerts sent here)
ADMIN_NOTIFY_EMAIL=ParagatosLiybie@gmail.com

# Supabase (required for Vercel production — JSON files used locally if omitted)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: for npm run setup:supabase (Database → Connection string URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

PORT=3000
